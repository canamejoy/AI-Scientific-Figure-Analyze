# ─────────────────────────────────────────────────────────────────────────
# Scientific Figure Extractor — environment configuration
# Copy this file to `.env` and adjust if needed. No API keys are required.
# ─────────────────────────────────────────────────────────────────────────

# Page-layout detection model (DocLayout-YOLO) is the primary figure locator.
# Set to "off" to force the caption-anchor heuristics instead.
# LAYOUT_DETECTION=on

# Use local layout-model weights instead of downloading from the HF Hub.
# LAYOUT_MODEL_PATH=C:\models\doclayout_yolo_docstructbench_imgsz1024.pt
